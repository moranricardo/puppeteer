name: El Toroide Adiamantado (Evolución 818)

on:
  push:
    branches: [ main ]
  workflow_dispatch:
  schedule:
    # Se ejecuta automáticamente cada 30 minutos
    - cron: '*/30 * * * *'

jobs:
  build:
    runs-on: ubuntu-latest
    env:
      # DEBUG: "puppeteer:*" # Descomenta solo si necesitas depurar errores
      NODE_ENV: production
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 22

      - name: Install OS Dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            ca-certificates fonts-liberation libasound2t64 \
            libatk-bridge2.0-0 libatk1.0-0 libc6 libcairo2 \
            libcups2 libdbus-1-3 libexpat1 libfontconfig1 \
            libgbm1 libgcc1 libglib2.0-0 libgtk-3-0 libnspr4 \
            libnss3 libpango-1.0-0 libpangocairo-1.0-0 libstdc++6 \
            libx11-6 libx11-xcb1 libxcb1 libxcomposite1 libxcursor1 \
            libxdamage1 libxext6 libxfixes3 libxi6 libxrandr2 \
            libxrender1 libxss1 libxtst6 lsb-release wget xdg-utils

      - name: Install Dependencies
        run: npm install

      - name: Install Puppeteer Browser
        run: npx puppeteer browsers install chrome

      - name: Ejecutar Ciclo del Vórtice
        run: node index.js

      - name: Persistencia del Núcleo
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add diamond_core.json
          git diff --quiet && git diff --staged --quiet || (git commit -m "Update Diamond Core: Evolución 818 [skip ci]" && git push)