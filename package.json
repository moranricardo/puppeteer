{
  "name": "protocolo-818-core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Motor de automatización basado en Chromium, optimizado para entornos de baja memoria y scraping inteligente.",
  "scripts": {
    "build": "wireit",
    "format": "prettier --write --cache .",
    "lint": "eslint --cache .",
    "test-bridge": "node test-bridge.js"
  },
  "wireit": {
    "build": {
      "dependencies": [
        "./packages/browsers:build",
        "./packages/puppeteer-core:build",
        "./packages/puppeteer:build"
      ]
    }
  },
  "devDependencies": {
    "@actions/core": "3.0.0",
    "@types/mocha": "10.0.10",
    "@types/node": "22.13.10",
    "typescript": "5.8.3",
    "eslint": "9.39.3",
    "mocha": "11.7.5",
    "prettier": "3.8.1",
    "wireit": "0.14.12",
    "glob": "13.0.6"
  },
  "workspaces": [
    "packages/*"
  ]
}